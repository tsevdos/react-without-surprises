{
  "name": "react-without-surprises",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "check": "pnpm check:ts && pnpm check:lint && pnpm check:format",
    "check:ts": "tsc --noEmit --pretty",
    "check:lint": "oxlint",
    "check:format": "oxfmt --check",
    "fix": "pnpm fix:lint && pnpm fix:format",
    "fix:lint": "oxlint --fix",
    "fix:format": "oxfmt"
  },
  "dependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@rolldown/plugin-babel": "^0.2.3",
    "@types/babel__core": "^7.20.5",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.12"
  }
}
